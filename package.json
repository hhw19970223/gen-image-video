    "nanoid": "5.0.7",
    "next": "15.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
